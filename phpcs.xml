<?xml version="1.0"?>
<ruleset name="Galaxon PHP Coding Standard">
    <description>Coding standard for Galaxon PHP libraries</description>

    <!-- Paths to check -->
    <file>src</file>

    <!-- Galaxon Coding Standard (includes PSR12 + custom rules) -->
    <rule ref="Galaxon"/>

    <exclude-pattern>*/Tests/*.inc</exclude-pattern>
    <exclude-pattern>*/Tests/*.inc.fixed</exclude-pattern>
    <exclude-pattern>*/ScopeIndentSniff.php</exclude-pattern>

</ruleset>
